diff --git a/modules/skparagraph/src/ParagraphImpl.cpp b/modules/skparagraph/src/ParagraphImpl.cpp
index 7a4b8c13e8..deaa098c7e 100644
--- a/modules/skparagraph/src/ParagraphImpl.cpp
+++ b/modules/skparagraph/src/ParagraphImpl.cpp
@@ -550,6 +550,35 @@ void ParagraphImpl::buildClusterTable() {
     }
     fClustersIndexFromCodeUnit[fText.size()] = fClusters.size();
     fClusters.emplace_back(this, EMPTY_RUN, 0, 0, this->text({fText.size(), fText.size()}), 0, 0);
+
+    // Defensive fix: ensure there are no EMPTY_INDEX entries left in
+    // fClustersIndexFromCodeUnit. In some cases (segmentation/bidi
+    // boundaries) certain code unit positions may not get assigned a
+    // cluster index above, which later causes an assertion in
+    // ParagraphImpl::clusterIndex. Fill any gaps by propagating the
+    // nearest known cluster index (left-to-right, then right-to-left)
+    // so that every code unit maps to a valid cluster.
+    const size_t n = fText.size();
+    size_t last = EMPTY_INDEX;
+    for (size_t i = 0; i <= n; ++i) {
+        if (fClustersIndexFromCodeUnit[i] == EMPTY_INDEX) {
+            if (last != EMPTY_INDEX) {
+                fClustersIndexFromCodeUnit[i] = last;
+            }
+        } else {
+            last = fClustersIndexFromCodeUnit[i];
+        }
+    }
+    size_t next = EMPTY_INDEX;
+    for (size_t i = n + 1; i-- > 0;) {
+        if (fClustersIndexFromCodeUnit[i] == EMPTY_INDEX) {
+            if (next != EMPTY_INDEX) {
+                fClustersIndexFromCodeUnit[i] = next;
+            }
+        } else {
+            next = fClustersIndexFromCodeUnit[i];
+        }
+    }
 }
 
